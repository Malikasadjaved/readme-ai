    "readme",
    "documentation",
    "ai",
    "generator",
    "markdown",
    "github",
    "claude",
    "openai",
    "mermaid",
    "developer-tools"
  ],
  "homepage": "https://github.com/malikasadjaved/readme-ai",
  "repository": {
